<!--
    LOGINVIEW.AXAML — Page d'accueil : connexion et création de compte
    DataContext = LoginViewModel (lié automatiquement par ViewLocator)
    STRUCTURE :
      - Titre principal en haut
      - Deux cartes côte à côte (Grid 2 colonnes :formulaire de CONNEXION,formulaire d'INSCRIPTION)
-->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyProjectBase.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="MyProjectBase.Views.LoginView"
             x:DataType="vm:LoginViewModel"> 

    <Grid Background="#0D0D0D" RowDefinitions="Auto,*">

        <!-- TITRE DE L'APPLICATION -->
        <TextBlock Grid.Row="0"
                   Text="Ma Collection de Voitures"
                   FontSize="28" FontWeight="Bold"
                   Foreground="#D4AF37" HorizontalAlignment="Center"
                   Margin="0,30,0,10"/><!-- Or = couleur d'accent du thème -->

        <!-- ScrollViewer : permet de défiler si l'écran est trop petit -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <Grid ColumnDefinitions="*,*" Margin="40,20,40,40"> <!-- 2 colonnes égales -->

                <!--
                FORMULAIRE DE CONNEXION
                Lié à LoginUsername, LoginPassword, LoginCommand
                -->
                <Border Grid.Column="0" Margin="0,0,20,0"
                        Background="#121212" BorderBrush="#2A2A2A"
                        BorderThickness="1" CornerRadius="20" Padding="35">
                    <StackPanel Spacing="18" VerticalAlignment="Center">

                        <TextBlock Text="Connexion"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"/>

                        <Rectangle Height="1" Fill="#2A2A2A"/> <!-- Séparateur visuel -->

                        <!-- Champ Nom d'utilisateur (accepte aussi l'email grâce à LoginAsync) -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Nom d'utilisateur ou Email" Foreground="#BBBBBB" FontSize="13"/>
                            <TextBox Text="{Binding LoginUsername}" Watermark="ex: utilisateur / utilisateur@gmail.com"
                                     Background="#1E1E1E" Foreground="White"
                                     BorderBrush="#3A3A3A" CornerRadius="10" Padding="12,10"/><!-- Lié à LoginViewModel.LoginUsername -->
                        </StackPanel>

                        <!-- Champ mot de passe — PasswordChar masque la saisie avec ● -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Mot de passe" Foreground="#BBBBBB" FontSize="13"/>
                            <TextBox Text="{Binding LoginPassword}"
                                     PasswordChar="●" Watermark="••••••"
                                     Background="#1E1E1E" Foreground="White"
                                     BorderBrush="#3A3A3A" CornerRadius="10" Padding="12,10"/>
                        </StackPanel>

                        <!--
                            Message d'erreur (identifiants incorrects, erreur réseau, etc.)
                            IsVisible lié à la propriété LoginErrorMessage via StringConverters.IsNotNullOrEmpty
                            → visible seulement si LoginErrorMessage n'est pas null/vide
                        -->
                        <TextBlock Text="{Binding LoginErrorMessage}"
                                   Foreground="#FF6B6B" FontSize="12"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   IsVisible="{Binding LoginErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                        <!--
                            Bouton de connexion
                            IsEnabled={Binding !IsLoading} → désactivé pendant l'appel MongoDB (évite double-clic)
                            Le contenu change selon IsLoading : "Se connecter" ↔ "Connexion..."
                        -->
                        <Button Command="{Binding LoginCommand}"
                                IsEnabled="{Binding !IsLoading}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#D4AF37" Foreground="Black"
                                FontWeight="Bold" FontSize="15"
                                CornerRadius="12" Padding="0,14">
                            <Panel>
                                <!-- Texte normal (quand pas en chargement) -->
                                <TextBlock Text="Se connecter"
                                           IsVisible="{Binding !IsLoading}"
                                           HorizontalAlignment="Center"/>
                                <!-- Texte de chargement (pendant l'appel MongoDB) -->
                                <TextBlock Text="Connexion..."
                                           IsVisible="{Binding IsLoading}"
                                           HorizontalAlignment="Center"/>
                            </Panel>
                        </Button>

                    </StackPanel>
                </Border>

                <!--
                FORMULAIRE D'INSCRIPTION
                Lié à RegisterUsername, RegisterEmail, RegisterPassword,
                RegisterPasswordConfirm, RegisterCommand
                -->
                <Border Grid.Column="1" Margin="20,0,0,0"
                        Background="#121212" BorderBrush="#2A2A2A"
                        BorderThickness="1" CornerRadius="20" Padding="35">
                    <StackPanel Spacing="14" VerticalAlignment="Center">

                        <TextBlock Text="Créer un compte"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"/>

                        <Rectangle Height="1" Fill="#2A2A2A"/>

                        <!-- Champ nom d'utilisateur (obligatoire, marqué *) -->
                        <StackPanel Spacing="5">
                            <TextBlock Text="Nom d'utilisateur *" Foreground="#BBBBBB" FontSize="13"/>
                            <TextBox Text="{Binding RegisterUsername}"
                                     Watermark="ex: utilisateur"
                                     Background="#1E1E1E" Foreground="White"
                                     BorderBrush="#3A3A3A" CornerRadius="10" Padding="12,8"/>
                        </StackPanel>
                        
                        <!-- Champ email (obligatoire, validé par Regex dans LoginViewModel) -->
                        <StackPanel Spacing="5">
                            <TextBlock Text="Email *" Foreground="#BBBBBB" FontSize="13"/>
                            <TextBox Text="{Binding RegisterEmail}"
                                     Watermark="ex: utilisateur@gmail.com"
                                     Background="#1E1E1E"
                                     Foreground="White"
                                     BorderBrush="#3A3A3A"
                                     CornerRadius="10"
                                     Padding="12,8"/>
                        </StackPanel>

                        <!-- Mot de passe (min 6 caractères, validé dans LoginViewModel.Register) -->
                        <StackPanel Spacing="5">
                            <TextBlock Text="Mot de passe * (min. 6 caractères)" Foreground="#BBBBBB" FontSize="13"/>
                            <TextBox Text="{Binding RegisterPassword}"
                                     PasswordChar="●" Watermark="••••••"
                                     Background="#1E1E1E" Foreground="White"
                                     BorderBrush="#3A3A3A" CornerRadius="10" Padding="12,8"/>
                        </StackPanel>

                        <!-- Confirmation : doit être identique au mot de passe -->
                        <StackPanel Spacing="5">
                            <TextBlock Text="Confirmer le mot de passe *" Foreground="#BBBBBB" FontSize="13"/>
                            <TextBox Text="{Binding RegisterPasswordConfirm}"
                                     PasswordChar="●" Watermark="••••••"
                                     Background="#1E1E1E" Foreground="White"
                                     BorderBrush="#3A3A3A" CornerRadius="10" Padding="12,8"/>
                        </StackPanel>

                        <!--
                            Message d'erreur OU de succès (même TextBlock, couleur rouge dans les 2 cas)
                        -->
                        <TextBlock Text="{Binding RegisterErrorMessage}"
                                   Foreground="#FF6B6B" FontSize="12"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   IsVisible="{Binding RegisterErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                        <!-- Bouton inscription  -->
                        <Button Content="Créer un compte"
                                Command="{Binding RegisterCommand}"
                                IsEnabled="{Binding !IsLoading}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#1E1E1E" Foreground="#D4AF37"
                                FontWeight="SemiBold" FontSize="14"
                                BorderBrush="#D4AF37" BorderThickness="1"
                                CornerRadius="12" Padding="0,12"/>

                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
